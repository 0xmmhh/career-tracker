# Google Custom Search JSON API (used only by `npm run discover`)
# Get a key: https://developers.google.com/custom-search/v1/introduction
# Create a search engine (set to "search entire web"): https://programmablesearchengine.google.com/
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Background check interval in hours (used if you wire monitor to cron). Default reference only.
CHECK_INTERVAL_HOURS=24

# DeepSeek API (OpenAI-compatible) — powers job-fit analysis and CV tailoring.
# Get a key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# Optional overrides (defaults shown):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
